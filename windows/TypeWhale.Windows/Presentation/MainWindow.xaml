<Window x:Class="TypeWhale.Windows.Presentation.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TypeWhale"
        Width="1120"
        Height="820"
        MinWidth="980"
        MinHeight="720"
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        Background="#111418">
    <Window.Resources>
        <SolidColorBrush x:Key="PageBackground" Color="#111418" />
        <SolidColorBrush x:Key="PanelBackground" Color="#1B1E23" />
        <SolidColorBrush x:Key="PanelBackgroundSoft" Color="#202329" />
        <SolidColorBrush x:Key="PanelBorder" Color="#2A2F36" />
        <SolidColorBrush x:Key="PrimaryText" Color="#F4F5F7" />
        <SolidColorBrush x:Key="SecondaryText" Color="#B7BBC2" />
        <SolidColorBrush x:Key="MutedText" Color="#777D86" />
        <SolidColorBrush x:Key="Accent" Color="#FFC91E" />
        <SolidColorBrush x:Key="ReadyGreen" Color="#29E36F" />

        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
            <Setter Property="BorderBrush" Value="{StaticResource PanelBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="Padding" Value="24" />
        </Style>

        <Style x:Key="IconTile" TargetType="Border">
            <Setter Property="Width" Value="44" />
            <Setter Property="Height" Value="44" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Background" Value="#292C31" />
        </Style>

        <Style x:Key="FlatButton" TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource PrimaryText}" />
            <Setter Property="Background" Value="#2A2D32" />
            <Setter Property="BorderBrush" Value="#30343A" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="13"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="{StaticResource PageBackground}"
            SnapsToDevicePixels="True">
        <Grid Margin="28">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.38*" />
                    <ColumnDefinition Width="32" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="92" />
                        <RowDefinition Height="300" />
                        <RowDefinition Height="182" />
                        <RowDefinition Height="128" />
                        <RowDefinition Height="128" />
                        <RowDefinition Height="80" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border Width="68"
                                Height="68"
                                CornerRadius="12"
                                Background="{StaticResource Accent}"
                                VerticalAlignment="Top">
                            <Grid>
                                <Ellipse Width="8"
                                         Height="8"
                                         Fill="#5B4C08"
                                         HorizontalAlignment="Right"
                                         VerticalAlignment="Top"
                                         Margin="0,18,17,0" />
                                <TextBlock Text="~~~"
                                           Foreground="#5B4C08"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Margin="0,-2,0,0" />
                            </Grid>
                        </Border>

                        <StackPanel Grid.Column="1"
                                    Margin="18,7,0,0">
                            <TextBlock Text="TypeWhale"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="28"
                                       FontWeight="Bold" />
                            <TextBlock Text="Version 1.2.8 (151)"
                                       Foreground="{StaticResource SecondaryText}"
                                       FontSize="15"
                                       Margin="0,4,0,0" />
                        </StackPanel>

                        <Button Grid.Column="2"
                                Width="42"
                                Height="42"
                                Margin="0,10,4,0"
                                Style="{StaticResource FlatButton}"
                                Background="Transparent"
                                BorderThickness="0"
                                Content="⚙"
                                FontSize="24" />
                    </Grid>

                    <Border Grid.Row="1"
                            Style="{StaticResource Card}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0"
                                  Height="118"
                                  VerticalAlignment="Top"
                                  Margin="0,12,0,0">
                                <TextBlock Text="· · · · · · · · · · · · · ·"
                                           Foreground="#856F15"
                                           FontSize="26"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Margin="54,0,0,0" />
                                <TextBlock Text="|"
                                           Foreground="{StaticResource Accent}"
                                           FontSize="38"
                                           HorizontalAlignment="Left"
                                           VerticalAlignment="Center"
                                           Margin="166,0,0,0" />
                                <TextBlock Text="· · · · · · · · · · · · · ·"
                                           Foreground="#856F15"
                                           FontSize="26"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,50,0" />
                                <TextBlock Text="|"
                                           Foreground="{StaticResource Accent}"
                                           FontSize="38"
                                           HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Margin="0,0,170,0" />

                                <Border Width="112"
                                        Height="112"
                                        CornerRadius="56"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Background="{StaticResource Accent}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#FFC91E"
                                                          BlurRadius="34"
                                                          ShadowDepth="0"
                                                          Opacity="0.45" />
                                    </Border.Effect>
                                    <Grid>
                                        <Ellipse Width="10"
                                                 Height="10"
                                                 Fill="#5B4C08"
                                                 HorizontalAlignment="Right"
                                                 VerticalAlignment="Top"
                                                 Margin="0,30,28,0" />
                                        <TextBlock Text="~~~"
                                                   Foreground="#5B4C08"
                                                   FontSize="32"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="0,-3,0,0" />
                                    </Grid>
                                </Border>
                            </Grid>

                            <TextBlock x:Name="StatusText"
                                       Grid.Row="1"
                                       Text="等待语音输入"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="28"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,14" />
                            <TextBlock x:Name="DetailText"
                                       Grid.Row="2"
                                       Text="按住自定义快捷键开始录音，松开自动粘贴"
                                       Foreground="{StaticResource SecondaryText}"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       TextWrapping="Wrap"
                                       HorizontalAlignment="Center"
                                       Margin="0,0,0,24" />
                            <Button x:Name="RecordButton"
                                    Grid.Row="3"
                                    Width="164"
                                    Height="62"
                                    Padding="0"
                                    Style="{StaticResource FlatButton}"
                                    Content="设置快捷键"
                                    Click="RecordButton_Click"
                                    FontSize="15" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Style="{StaticResource Card}"
                            Margin="0,14,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Row="0" Style="{StaticResource IconTile}">
                                <TextBlock Text="Mic"
                                           Foreground="{StaticResource Accent}"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Row="0"
                                       Grid.Column="1"
                                       Text="麦克风权限"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0" />
                            <Ellipse Grid.Row="0"
                                     Grid.Column="2"
                                     Width="14"
                                     Height="14"
                                     Fill="{StaticResource Accent}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,14,0" />
                            <TextBlock Grid.Row="0"
                                       Grid.Column="3"
                                       Text="已开启  ›"
                                       Foreground="{StaticResource SecondaryText}"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />

                            <Border Grid.Row="1" Style="{StaticResource IconTile}">
                                <TextBlock Text="A11y"
                                           Foreground="{StaticResource Accent}"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="辅助功能权限"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0" />
                            <Ellipse Grid.Row="1"
                                     Grid.Column="2"
                                     Width="14"
                                     Height="14"
                                     Fill="{StaticResource Accent}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,14,0" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="3"
                                       Text="已开启  ›"
                                       Foreground="{StaticResource SecondaryText}"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />

                            <Border Grid.Row="2" Style="{StaticResource IconTile}">
                                <TextBlock Text="Key"
                                           Foreground="{StaticResource Accent}"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center" />
                            </Border>
                            <TextBlock Grid.Row="2"
                                       Grid.Column="1"
                                       Text="全局快捷键"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="18,0,0,0" />
                            <Ellipse Grid.Row="2"
                                     Grid.Column="2"
                                     Width="14"
                                     Height="14"
                                     Fill="{StaticResource Accent}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,14,0" />
                            <TextBlock Grid.Row="2"
                                       Grid.Column="3"
                                       Text="监听中  ›"
                                       Foreground="{StaticResource SecondaryText}"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Grid Grid.Row="3"
                          Margin="0,14,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="14" />
                            <ColumnDefinition />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0"
                                Style="{StaticResource Card}"
                                Padding="18">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="主快捷键"
                                           Foreground="{StaticResource PrimaryText}"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                                <TextBlock x:Name="MainShortcutText"
                                           Text="Ctrl + Alt + Space"
                                           Foreground="{StaticResource Accent}"
                                           FontSize="27"
                                           FontWeight="Bold"
                                           Margin="0,18,0,0"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2"
                                Style="{StaticResource Card}"
                                Padding="18">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock Text="备用快捷键"
                                           Foreground="{StaticResource PrimaryText}"
                                           FontSize="17"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center" />
                                <TextBlock Text="未设置"
                                           Foreground="{StaticResource Accent}"
                                           FontSize="27"
                                           FontWeight="Bold"
                                           Margin="0,18,0,0"
                                           HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="4"
                            Style="{StaticResource Card}"
                            Margin="0,14,0,0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="本地识别模型"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="17"
                                       FontWeight="Bold" />
                            <Border Grid.Column="1"
                                    Background="{StaticResource Accent}"
                                    CornerRadius="9"
                                    Padding="12,7"
                                    VerticalAlignment="Top">
                                <TextBlock Text="已就绪"
                                           Foreground="#5B4500"
                                           FontWeight="Bold" />
                            </Border>
                            <TextBlock Grid.Row="1"
                                       Text="SenseVoice int8"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="22"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="1"
                                       Text="0.35 秒"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="21"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="5"
                            Style="{StaticResource Card}"
                            Margin="0,14,0,0"
                            Padding="0">
                        <Button Style="{StaticResource FlatButton}"
                                Background="#23262B"
                                BorderThickness="0"
                                Padding="0"
                                Height="62"
                                Content="高级诊断" />
                    </Border>
                </Grid>

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="122" />
                        <RowDefinition Height="222" />
                        <RowDefinition Height="352" />
                        <RowDefinition Height="282" />
                        <RowDefinition Height="78" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0"
                               Text="状态"
                               Foreground="{StaticResource PrimaryText}"
                               FontSize="20"
                               FontWeight="Bold"
                               Margin="26,8,0,8" />

                    <Border Grid.Row="1"
                            Style="{StaticResource Card}"
                            Padding="24,20"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="18"
                                             Height="18"
                                             Fill="{StaticResource ReadyGreen}"
                                             VerticalAlignment="Center" />
                                    <TextBlock Text="就绪"
                                               Foreground="{StaticResource ReadyGreen}"
                                               FontSize="20"
                                               FontWeight="Bold"
                                               Margin="12,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="本地语音识别引擎已加载"
                                           Foreground="{StaticResource SecondaryText}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           Margin="0,12,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        HorizontalAlignment="Right">
                                <TextBlock Text="SenseVoice int8"
                                           Foreground="{StaticResource PrimaryText}"
                                           FontSize="15"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Right" />
                                <TextBlock Text="本地引擎"
                                           Foreground="{StaticResource SecondaryText}"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Right"
                                           Margin="0,28,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="2"
                            Style="{StaticResource Card}"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="1" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="权限状态"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="18"
                                       FontWeight="Bold" />
                            <Border Grid.Row="1"
                                    Height="1"
                                    Margin="0,14,0,18"
                                    Background="#333840" />
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                    <ColumnDefinition />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <Border Style="{StaticResource IconTile}">
                                        <TextBlock Text="Mic"
                                                   Foreground="{StaticResource Accent}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="麦克风"
                                               Foreground="{StaticResource PrimaryText}"
                                               FontWeight="Bold"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               Margin="0,12,0,0" />
                                    <TextBlock Text="已开启"
                                               Foreground="{StaticResource SecondaryText}"
                                               FontWeight="SemiBold"
                                               FontSize="15"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                    <Border Style="{StaticResource IconTile}">
                                        <TextBlock Text="A11y"
                                                   Foreground="{StaticResource Accent}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="辅助功能"
                                               Foreground="{StaticResource PrimaryText}"
                                               FontWeight="Bold"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               Margin="0,12,0,0" />
                                    <TextBlock Text="已开启"
                                               Foreground="{StaticResource SecondaryText}"
                                               FontWeight="SemiBold"
                                               FontSize="15"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <Border Style="{StaticResource IconTile}">
                                        <TextBlock Text="Key"
                                                   Foreground="{StaticResource Accent}"
                                                   FontWeight="Bold"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="全局快捷键"
                                               Foreground="{StaticResource PrimaryText}"
                                               FontWeight="Bold"
                                               FontSize="16"
                                               HorizontalAlignment="Center"
                                               Margin="0,12,0,0" />
                                    <TextBlock Text="监听中"
                                               Foreground="{StaticResource SecondaryText}"
                                               FontWeight="SemiBold"
                                               FontSize="15"
                                               HorizontalAlignment="Center"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <Border Grid.Row="3"
                            Style="{StaticResource Card}"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="1" />
                                <RowDefinition Height="52" />
                                <RowDefinition Height="52" />
                                <RowDefinition Height="1" />
                                <RowDefinition Height="64" />
                                <RowDefinition Height="52" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="快捷键"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="18"
                                       FontWeight="Bold" />
                            <Border Grid.Row="1"
                                    Background="#333840"
                                    Margin="0,14,0,0" />

                            <TextBlock Grid.Row="2"
                                       Text="主快捷键"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Row="2"
                                       x:Name="SidebarShortcutText"
                                       Text="Ctrl + Alt + Space"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Row="3"
                                       Text="快捷键设置"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <Button x:Name="ChangeHotkeyButton"
                                    Grid.Row="3"
                                    Style="{StaticResource FlatButton}"
                                    Content="更改"
                                    Click="ChangeHotkeyButton_Click"
                                    Padding="18,8"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center" />
                            <Border Grid.Row="4"
                                    Background="#333840" />
                            <TextBlock Grid.Row="5"
                                       Text="本地模型"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="17"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center" />
                            <Border Grid.Row="5"
                                    Background="{StaticResource Accent}"
                                    CornerRadius="9"
                                    Padding="12,7"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                                <TextBlock Text="已就绪"
                                           Foreground="#5B4500"
                                           FontWeight="Bold" />
                            </Border>
                            <TextBlock Grid.Row="6"
                                       Text="平均延迟"
                                       Foreground="{StaticResource SecondaryText}"
                                       FontSize="17"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Row="6"
                                       Text="0.35 秒"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="19"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Right"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <Border Grid.Row="4"
                            Style="{StaticResource Card}"
                            Margin="0,0,0,14">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="最近转录"
                                       Foreground="{StaticResource PrimaryText}"
                                       FontSize="18"
                                       FontWeight="Bold" />
                            <ListBox x:Name="HistoryList"
                                     Grid.Row="1"
                                     Margin="0,18,0,0"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     ScrollViewer.VerticalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0" />
                                        <Setter Property="Margin" Value="0,0,0,12" />
                                        <Setter Property="Background" Value="Transparent" />
                                        <Setter Property="BorderThickness" Value="0" />
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Height="44">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="72" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="32" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="{StaticResource Accent}"
                                                    CornerRadius="10"
                                                    Padding="10,7"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding RecognitionSeconds, StringFormat={}{0:F2} 秒}"
                                                           Foreground="#5B4500"
                                                           FontWeight="Bold"
                                                           FontSize="14" />
                                            </Border>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Text}"
                                                       Foreground="{StaticResource PrimaryText}"
                                                       FontSize="15"
                                                       FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis"
                                                       VerticalAlignment="Center"
                                                       Margin="12,0,8,0" />
                                            <TextBlock Grid.Column="2"
                                                       Text="⧉"
                                                       Foreground="{StaticResource SecondaryText}"
                                                       FontSize="18"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>

                    <Border Grid.Row="5"
                            Style="{StaticResource Card}"
                            Padding="0">
                        <Button Style="{StaticResource FlatButton}"
                                Background="#23262B"
                                BorderThickness="0"
                                Padding="0"
                                Height="62"
                                Content="查看全部历史记录  ›" />
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Border>
